{
  "manifest_version": 3,
  "name": "Multi-Site Inventory Exporter",
  "version": "1.0.0",
  "description": "Capture supplier-page data and submit raw captures to the Multi-Site Supplier Importer plugin for InvenTree.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://www.mcmaster.com/*",
    "https://boltdepot.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
